# /mobile/.htaccess – Liberar assets estáticos do PWA

# MIME types
AddType application/manifest+json .webmanifest
AddType application/json .json

# Liberar manifest por nome exato
<Files "manifest.webmanifest">
  Require all granted
</Files>

<Files "manifest.json">
  Require all granted
</Files>

<Files "sw.js">
  Require all granted
</Files>

# Liberar assets estáticos por extensão
<FilesMatch "\.(css|js|png|jpg|jpeg|gif|svg|ico|webmanifest|json|woff2?)$">
  Require all granted
</FilesMatch>

# CORS para manifest (necessário em alguns navegadores)
<IfModule mod_headers.c>
  <FilesMatch "\.(webmanifest|json)$">
    Header set Access-Control-Allow-Origin "*"
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
  <FilesMatch "sw\.js$">
    Header set Service-Worker-Allowed "/"
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
